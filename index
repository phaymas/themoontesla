    // ---------- Tesla Sold ----------
    function renderTeslaStore(){
      let html = `<h3><i class="fas fa-car"></i> Tesla Showroom</h3><p>Balance: $${accountBalance.toLocaleString()}</p>`;
      teslaProducts.forEach(p => {
        html += `<div class="tesla-item" data-tesla-id="${p.id}" data-price="${p.price}" data-name="${p.name}">
          <div class="tesla-img"><i class="fas ${p.icon}"></i></div>
          <div class="tesla-info">
            <div class="name">${p.name}</div>
            <div class="price-tag">$${p.price.toLocaleString()}</div>
          </div>
        </div>`;
      });
      html += `<div class="action-btn exit" id="closeTeslaStore">Close</div>`;
      modalBody.innerHTML = html;
      document.querySelectorAll('.tesla-item').forEach(item => {
        item.addEventListener('click', () => {
          const name = item.dataset.name;
          const price = parseInt(item.dataset.price);
          renderTeslaPurchase(name, price);
        });
      });
      document.getElementById('closeTeslaStore').addEventListener('click', ()=>modal.classList.remove('active'));
      modal.classList.add('active');
    }

    function renderTeslaPurchase(name, price){
      modalBody.innerHTML = `<h3>${name}</h3>
        <div style="font-size:2rem;color:#f5e3b6;">$${price.toLocaleString()}</div>
        <p>Confirm purchase?</p>
        <div class="action-buttons">
          <div class="action-btn order" data-action="buy">🛒 Buy Now</div>
          <div class="action-btn exit" data-action="cancel">Cancel</div>
        </div>`;
      document.querySelector('[data-action="buy"]').addEventListener('click', ()=>{
        if(accountBalance < price){ alert(`Insufficient balance! Need $${price.toLocaleString()}.`); return; }
        accountBalance -= price;
        const orderId = 'TSLA-'+Date.now().toString().slice(-6);
        const order = { id:orderId, tier:name, price, date:new Date().toLocaleDateString() };
        orders.push(order);
        updateBalanceDisplay();
        modalBody.innerHTML = `<div style="text-align:center;"><i class="fas fa-check-circle" style="font-size:4rem;color:#4caf50;"></i><h3>Purchase Successful!</h3>
          <div style="background:rgba(0,0,0,0.2);border-radius:24px;padding:1.5rem;text-align:left;">
            <div class="order-detail-row"><span>Order ID:</span><strong>${order.id}</strong></div>
            <div class="order-detail-row"><span>Product:</span><strong>${name}</strong></div>
            <div class="order-detail-row"><span>Price:</span><strong>$${price.toLocaleString()}</strong></div>
          </div>
          <div class="action-buttons"><div class="action-btn exit" id="closeTeslaSuccess">Close</div></div></div>`;
        document.getElementById('closeTeslaSuccess').addEventListener('click', ()=>modal.classList.remove('active'));
      });
      document.querySelector('[data-action="cancel"]').addEventListener('click', renderTeslaStore);
    }

    document.getElementById('teslaSoldBtn').addEventListener('click', renderTeslaStore);

    // ---------- THE MOON 购买逻辑 (购买限制10000) ----------
    function renderDynamicList(){
      let html = `<h3><i class="fas fa-cubes"></i> Choose Your Dynamic</h3><p>Current discount: ${(discountRate*100).toFixed(0)}% · Balance: $${accountBalance.toLocaleString()}</p>`;
      Object.keys(tierPrices).forEach(key=>{
        const original = tierPrices[key];
        const discounted = getDiscountedPrice(key);
        const discountNote = discountRate<1 ? `<span class="discount-badge">-${100-discountRate*100}%</span>` : '';
        html += `<div class="dynamic-option" data-tier="${key}">
          <div class="name">${tierNames[key]} ${discountNote}</div>
          <div class="price-tag">$${discounted.toLocaleString()}</div>
          ${discountRate<1?`<div style="text-decoration:line-through;opacity:0.6;">$${original.toLocaleString()}</div>`:''}
          <div class="info-tip"><i class="fas fa-check"></i> ${tierDescs[key]}</div>
        </div>`;
      });
      modalBody.innerHTML = html;
      document.querySelectorAll('.dynamic-option').forEach(opt=> opt.addEventListener('click',()=> renderDynamicDetail(opt.dataset.tier)) );
      modal.classList.add('active');
    }

    function renderDynamicDetail(tierKey){
      const tier = tierNames[tierKey];
      const original = tierPrices[tierKey];
      const discounted = getDiscountedPrice(tierKey);
      modalBody.innerHTML = `<h3>${tier}</h3>
        <div style="font-size:2rem;color:#f5e3b6;">$${discounted.toLocaleString()}</div>
        ${discountRate<1?`<div style="text-decoration:line-through;">$${original.toLocaleString()}</div>`:''}
        <p>${tierDescs[tierKey]}</p>
        <div class="action-buttons">
          <div class="action-btn order" data-action="order" data-tier="${tierKey}">🛒 Order Now</div>
          <div class="action-btn exit" data-action="exit">🚪 Exit</div>
        </div>`;
      document.querySelector('[data-action="order"]').addEventListener('click',()=> processOrder(tierKey));
      document.querySelector('[data-action="exit"]').addEventListener('click', renderDynamicList);
    }

    function processOrder(tierKey){
      if(orders.length >= MAX_ORDERS){ alert(`You can only purchase up to ${MAX_ORDERS} units.`); return; }
      const price = getDiscountedPrice(tierKey);
      if(accountBalance < price){ alert(`Insufficient balance! Need $${price.toLocaleString()}.`); return; }
      accountBalance -= price;
      const orderId = 'MOON-'+Date.now().toString().slice(-6);
      const order = { id:orderId, tier:tierNames[tierKey], price, date:new Date().toLocaleDateString() };
      orders.push(order);
      updateBalanceDisplay();
      modalBody.innerHTML = `<div style="text-align:center;"><i class="fas fa-check-circle" style="font-size:4rem;color:#4caf50;"></i><h3>Payment Successful!</h3>
        <div style="background:rgba(0,0,0,0.2);border-radius:24px;padding:1.5rem;text-align:left;">
          <div class="order-detail-row"><span>Order ID:</span><strong>${order.id}</strong></div>
          <div class="order-detail-row"><span>Product:</span><strong>${order.tier}</strong></div>
          <div class="order-detail-row"><span>Price:</span><strong>$${order.price.toLocaleString()}</strong></div>
          <div class="order-detail-row"><span>Date:</span><strong>${order.date}</strong></div>
        </div>
        <div class="action-buttons"><div class="action-btn exit" id="closeSuccess">Close</div></div></div>`;
      document.getElementById('closeSuccess').addEventListener('click',()=>modal.classList.remove('active'));
    }

    function renderOrderList(){
      if(!orders.length){ modalBody.innerHTML=`<h3>My Orders</h3><p>No orders yet.</p><div class="action-btn exit" id="closeEmpty">Close</div>`; }
      else{
        let items = orders.map(o=>`<div style="background:rgba(0,0,0,0.2);border-radius:16px;padding:1rem;margin-bottom:10px;"><div>${o.tier}</div><div>$${o.price.toLocaleString()} · ${o.date}</div><small>ID: ${o.id}</small></div>`).join('');
        modalBody.innerHTML=`<h3>My Orders (${orders.length}/${MAX_ORDERS})</h3>${items}<div class="action-btn exit" id="closeOrders">Close</div>`;
      }
      modal.classList.add('active');
      document.getElementById('closeOrders')?.addEventListener('click',()=>modal.classList.remove('active'));
      document.getElementById('closeEmpty')?.addEventListener('click',()=>modal.classList.remove('active'));
    }

    function renderAccount(){
      modalBody.innerHTML=`<h3><i class="fas fa-user-circle"></i> My Account</h3>
        <div style="font-size:2.5rem;">$${accountBalance.toLocaleString()}</div>
        <p>Available balance</p><hr style="margin:20px 0;border-color:#3a5a7a;">
        <h4>Recent Transactions</h4>${orders.length?orders.map(o=>`<div class="order-detail-row"><span>${o.tier}</span><span>-$${o.price.toLocaleString()}</span></div>`).join(''):'<p>No transactions</p>'}
        <div class="action-btn exit" id="closeAccount">Close</div>`;
      modal.classList.add('active');
      document.getElementById('closeAccount').addEventListener('click',()=>modal.classList.remove('active'));
    }

    function renderDiscounts(){
      modalBody.innerHTML=`<h3><i class="fas fa-tags"></i> Recharge & Get Discount</h3>
        <div class="recharge-option" data-recharge="30000000" data-discount="0.7"><strong>💎 Recharge $30M</strong> · 30% off future purchases</div>
        <div class="recharge-option" data-recharge="300000000" data-discount="0.5"><strong>💎💎 Recharge $300M</strong> · 50% off</div>
        <div class="recharge-option" data-recharge="40000000000" data-discount="0.2"><strong>💎💎💎 Recharge $40B</strong> · 80% off (2折)</div>
        <p style="margin-top:20px;"><i class="fas fa-info-circle"></i> Recharging adds funds and applies the discount to all future orders.</p>
        <div class="action-btn exit" id="closeDiscounts">Close</div>`;
      modal.classList.add('active');
      document.querySelectorAll('.recharge-option').forEach(opt=> opt.addEventListener('click',()=>{
        const amt = parseInt(opt.dataset.recharge);
        const disc = parseFloat(opt.dataset.discount);
        accountBalance += amt;
        discountRate = disc;
        updateBalanceDisplay();
        modalBody.innerHTML=`<h3>✅ Recharge Successful!</h3><p>Added $${amt.toLocaleString()}. New balance: $${accountBalance.toLocaleString()}</p><p>Discount rate: ${disc*100}%</p><div class="action-btn exit" id="backFromRecharge">OK</div>`;
        document.getElementById('backFromRecharge').addEventListener('click', renderDiscounts);
      }));
      document.getElementById('closeDiscounts').addEventListener('click',()=>modal.classList.remove('active'));
    }

    document.getElementById('orderBtn').addEventListener('click', renderDynamicList);
    document.getElementById('viewOrderBtn').addEventListener('click', renderOrderList);
    document.getElementById('viewAccountBtn').addEventListener('click', renderAccount);
    document.getElementById('viewDiscountsBtn').addEventListener('click', renderDiscounts);
    document.querySelectorAll('a[href="#"]').forEach(a=>a.addEventListener('click',e=>e.preventDefault()));
  })();
</script>
