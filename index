    function initStars(){stars=[];for(let i=0;i<200;i++)stars.push({x:Math.random(),y:Math.random(),r:Math.random()*2+0.8,b:Math.random()*0.5+0.5,s:0.002+Math.random()*0.01,p:Math.random()*Math.PI*2});}
    function resizeCanvas(){w=window.innerWidth;h=window.innerHeight;canvas.width=w;canvas.height=h;drawStars();}
    function drawStars(){
      if(!w||!h)return;ctx.clearRect(0,0,w,h);let g=ctx.createRadialGradient(w*.5,h*.3,50,w*.5,h*.5,w*.9);g.addColorStop(0,'#03080f');g.addColorStop(1,'#0f1a26');ctx.fillStyle=g;ctx.fillRect(0,0,w,h);
      let t=Date.now()/1000;stars.forEach(s=>{let x=s.x*w,y=s.y*h;let tw=Math.sin(t*s.s*3+s.p)*0.2+0.8;let a=Math.min(s.b*tw,1);ctx.beginPath();ctx.arc(x,y,s.r,0,Math.PI*2);ctx.fillStyle=s.r>1.7?`rgba(255,245,210,${a})`:`rgba(190,215,255,${a})`;ctx.shadowColor=s.r>1.9?'#ffe6b3':'#aac8ff';ctx.shadowBlur=s.r*6;ctx.fill();ctx.shadowBlur=0;});
